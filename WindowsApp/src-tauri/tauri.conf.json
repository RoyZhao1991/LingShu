{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nous",
  "version": "0.1.0-7",
  "identifier": "com.royzhao.lingshu.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nous",
        "width": 1440,
        "height": 940,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost https: http:; frame-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Productivity",
    "shortDescription": "Nous (LingShu), an open-model agent runtime for Windows",
    "longDescription": "Nous (LingShu) is an open-model desktop agent runtime with persistent task threads, registered artifacts, and built-in file preview.",
    "copyright": "Copyright © 2026 Roy Zhao",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../Resources/DesignKB/": "DesignKB/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp",
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese"]
      },
      "wix": {
        "language": ["en-US", "zh-CN"],
        "bannerPath": "installer-assets/wix-banner.bmp",
        "dialogImagePath": "installer-assets/wix-dialog.bmp"
      }
    }
  }
}
